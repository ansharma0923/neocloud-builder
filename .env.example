# Database — SQLite for local dev (zero install, no Docker needed)
# For production use: postgresql://user:password@host:5432/neocloud_builder
DATABASE_URL="file:./dev.db"

# ─── Auth — not required for local single-user mode ───────────────────────────
# NEXTAUTH_SECRET="your-secret-here"
# NEXTAUTH_URL="http://localhost:3000"

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Never commit a real API key
OPENAI_API_KEY="sk-..."

# Model name for fast conversational responses
OPENAI_MODEL_FAST="gpt-4o-mini"

# Model name for deep reasoning and analysis
OPENAI_MODEL_REASONING="o1-preview"

# Model name for file/document Q&A
OPENAI_MODEL_FILE_QA="gpt-4o"

# Model name for structured JSON extraction
OPENAI_MODEL_STRUCTURED="gpt-4o"

# Model name for image generation
OPENAI_MODEL_IMAGE="dall-e-3"

# Model name for title/label generation
OPENAI_MODEL_TITLE="gpt-4o-mini"

# Model name for text embeddings
OPENAI_MODEL_EMBEDDING="text-embedding-3-small"

# Model name for content moderation
OPENAI_MODEL_MODERATION="omni-moderation-latest"

# ─── Storage ──────────────────────────────────────────────────────────────────
# Storage adapter to use: local | s3
STORAGE_ADAPTER="local"

# Base path for local file storage (relative to project root)
LOCAL_STORAGE_PATH="./uploads"

# ─── App ──────────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"

# Log level: error | warn | info | debug
LOG_LEVEL="info"
